  "keyFeatures": [
    "Multi-tenant company workspaces with isolation",
    "JWT-based authentication with refresh tokens",
    "Role-based access control (RBAC) with granular permissions",
    "Company creation via invites or approval requests",
    "Member invitation system with role assignment",
    "Time tracking with projects and categories",
    "Client management with sites and rate rules",
    "Platform admin capabilities",
    "Hierarchical supervision within companies",
    "Audit trails and soft deletes"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Register new user",
    "POST /api/auth/login - Authenticate user",
    "POST /api/auth/refresh - Refresh access token",
    "POST /api/auth/logout - Logout user",
    "GET /api/auth/me - Get current user",
    "GET /api/users - List users",
    "GET /api/companies - List companies",
    "POST /api/companies - Create company",
    "GET /api/company-requests - List company requests",
    "POST /api/company-requests - Request company creation",
    "GET /api/invitations - List invitations",
    "POST /api/invitations - Create invitation",
    "GET /api/permissions - List permissions",
    "GET /api/permission-requests - List permission requests",
    "GET /api/time-entries - List time entries",
    "POST /api/time-entries - Create time entry",
    "GET /api/projects - List projects",
    "POST /api/projects - Create project",
    "GET /api/clients - List clients",
    "POST /api/clients - Create client",
    "GET /api/time-entry-categories - List categories",
    "GET /health - Health check"
  ]
